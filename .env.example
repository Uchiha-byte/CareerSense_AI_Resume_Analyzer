# LLM Provider API Keys
OPENAI_API_KEY=your-api-leys
GEMINI_API_KEY=your-api-keys
OPENROUTER_API_KEY=your-api-keys

# LLM Router — max concurrent sessions per model (default: 3)
LLM_MAX_CONCURRENT_PER_MODEL=xxx

# Server
PORT="xxxx"

# CORS — comma-separated list of allowed frontend origins
FRONTEND_ORIGIN="http://localhost:5173,http://localhost:3000"

# Database path (default: careersense.db in project root)
DB_PATH="your db"
